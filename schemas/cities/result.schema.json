{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "x-gc-jsonl": {},
  "type": "object",
  "required": ["schema_version", "registry_path", "cities"],
  "properties": {
    "schema_version": { "type": "string", "const": "1" },
    "registry_path": { "type": "string" },
    "cities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path"],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
